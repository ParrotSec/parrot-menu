[Desktop Entry]
Name=javasnoop
Comment=Attach to an existing process (like a debugger) and instantly begin tampering with method calls, run custom code, or debugging
Encoding=UTF-8
Exec=parrot-exec --gui "javasnoop"
Icon=parrot_javasnoop
StartupNotify=false
Terminal=false
Type=Application
Categories=07-02-debuggers;
X-Parrot-Package=javasnoop
