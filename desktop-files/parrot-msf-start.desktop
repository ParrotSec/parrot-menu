[Desktop Entry]
Name=Start Metasploit Service
Comment=Start metasploit framework and back-end services
Encoding=UTF-8
Exec=parrot-exec --sudo msfstart
Icon=parrot_metasploit
StartupNotify=false
Terminal=true
Type=Application
Categories=serv-09-metasploit-service;
X-Parrot-Package=metasploit-framework
